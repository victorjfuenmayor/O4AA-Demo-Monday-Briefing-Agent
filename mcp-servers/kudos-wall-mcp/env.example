# Kudos Wall runs its own authorization server (real Cross-App Access /
# XAA -- see SETUP.md §12), so unlike every other sample server here, it
# needs its own signing key and public URL, in addition to the same
# generic-validator variables the others use.

# REQUIRED: this server's own RSA signing keypair (as a single-line JWK
# JSON blob, private key included -- used to mint the tokens it issues,
# and to derive the public JWKS it serves at /oauth2/kudos-wall/v1/keys).
# Generate one with:
#   python3 -c "from jwcrypto import jwk; print(jwk.JWK.generate(kty='RSA', size=2048, alg='RS256', use='sig').export())"
SIGNING_KEY_JWK=

# REQUIRED: the public HTTPS URL this server is reachable at (an ngrok
# tunnel for local dev, e.g. https://xxxx.ngrok-free.app) -- this becomes
# this server's issuer (PUBLIC_BASE_URL + /oauth2/kudos-wall). Must match
# the "Issuer URL" configured on the Kudos Wall app's Cross-App Access tab
# in the Okta console.
PUBLIC_BASE_URL=

# REQUIRED: Okta's real org domain -- used to fetch Okta's OWN public keys
# (https://{OKTA_ORG_DOMAIN}/oauth2/v1/keys) to verify an incoming ID-JAG's
# signature. Deliberately a *different* variable name from OKTA_DOMAIN
# below -- this server is simultaneously Okta's own JWT *validator* (for
# tokens it mints itself, via OKTA_DOMAIN below) and an ID-JAG *verifier*
# against Okta's real org keys (via this variable) -- collapsing the two
# into one variable would point one of those checks at the wrong keys.
OKTA_ORG_DOMAIN=

# --- Everything below is auth/okta_validator.py's generic config, reused
#     unmodified from every other sample server -- except here it's
#     validating THIS server's own self-issued tokens, not Okta's. ---

# REQUIRED: point this at PUBLIC_BASE_URL's host (no scheme), e.g.
# xxxx.ngrok-free.app -- the validator builds discovery/JWKS URLs as
# https://{OKTA_DOMAIN}/oauth2/{OKTA_AUTHORIZATION_SERVER_ID}/...
OKTA_DOMAIN=

# REQUIRED: must be exactly "kudos-wall" -- matches this server's own
# ISSUER_PATH (/oauth2/kudos-wall) in xaa_resource_as.py.
OKTA_AUTHORIZATION_SERVER_ID=kudos-wall

# OPTIONAL: expected audience (aud) claim -- matches RESOURCE_AUDIENCE in
# xaa_resource_as.py.
OKTA_AUDIENCE=api://kudos-wall

# OPTIONAL: required scopes (space-separated). Leave empty to skip.
OKTA_REQUIRED_SCOPES=kudos.read
