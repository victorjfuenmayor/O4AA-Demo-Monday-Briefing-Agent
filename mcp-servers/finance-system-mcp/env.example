# Okta Configuration for Finance System MCP Server Token Validation
# Copy this to .env and fill in your values
# This MCP server validates incoming tokens from Okta before granting tool access.

# REQUIRED: Your Okta tenant domain
OKTA_DOMAIN=ijtestcustom.oktapreview.com

# REQUIRED: Authorization Server ID for Finance MCP tokens
OKTA_AUTHORIZATION_SERVER_ID=auss2fth0mcIXHzVO1d7

# OPTIONAL: Expected audience (aud) claim in token
OKTA_AUDIENCE=

# OPTIONAL: Required scopes (space-separated)
OKTA_REQUIRED_SCOPES=
