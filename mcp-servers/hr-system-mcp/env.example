# Okta Configuration for HR System MCP Server Token Validation
# This MCP server validates incoming tokens from Okta before granting tool access.
# All other configuration is auto-discovered from the Okta discovery endpoint.

# REQUIRED: Your Okta tenant domain
# Example: dev-12345.okta.com
OKTA_DOMAIN=dev-12345.okta.com

# REQUIRED: Authorization Server ID for HR MCP tokens
# This is the ID of the authorization server that issues HR MCP tokens
# Example: hr-mcp-server (or auss... if using custom ID)
OKTA_AUTHORIZATION_SERVER_ID=hr-mcp-server

# OPTIONAL: Expected audience (aud) claim in token
# This is the resource server identifier your MCP tokens are issued for
# If not set, audience validation will be skipped
# Example: https://hr-mcp-server.example.com or hr-mcp-resource-server
OKTA_AUDIENCE=

# OPTIONAL: Required scopes (space-separated)
# Token MUST contain ALL of these scopes for access
# Leave empty to skip this check
# Example: mcp:read mcp:admin
OKTA_REQUIRED_SCOPES=

# OPTIONAL: Discovery protection (default: true)
# When true, tools/list without auth returns 401 to trigger OAuth.
# When false, allows unauthenticated tools/list (e.g. for gateway target registration).
# PROTECTED_DISCOVERY=true
