# Okta Configuration for Ticketing System MCP Server
# This MCP server validates incoming tokens from Okta before granting tool
# access, AND uses these same two values to build its own RFC 9728
# discovery document (/.well-known/oauth-protected-resource) -- the doc
# Okta's "MCP Server" registration auto-discovers at setup time to learn
# which authorization server protects this resource. Get both wrong and
# discovery will point Okta at the wrong (or no) authorization server.

# REQUIRED: Your Okta tenant domain
# Example: dev-12345.okta.com
OKTA_DOMAIN=dev-12345.okta.com

# REQUIRED: Authorization Server ID for Ticketing MCP tokens
# This is the ID of the authorization server that issues Ticketing MCP
# tokens -- e.g. the auss... ID of a custom authorization server you
# created for this resource.
OKTA_AUTHORIZATION_SERVER_ID=

# OPTIONAL: Expected audience (aud) claim in token
# This is the resource server identifier your MCP tokens are issued for
# If not set, audience validation will be skipped
OKTA_AUDIENCE=

# OPTIONAL: Required scopes (space-separated)
# Token MUST contain ALL of these scopes for access
# Leave empty to skip this check
OKTA_REQUIRED_SCOPES=
