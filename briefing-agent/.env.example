# Okta tenant
OKTA_DOMAIN=dev-12345.okta.com

# Agent's own OAuth client (registered against the AI Agent object in UD)
OKTA_AGENT_CLIENT_ID=
OKTA_AGENT_CLIENT_SECRET=

# One custom authorization server per native-XAA resource
HR_AUTH_SERVER_ID=
FINANCE_AUTH_SERVER_ID=

# Okta Privileged Access (OPA) -- vaulted secret for Ticketing/Analytics.
# Leave OPA_DOMAIN unset to fall back to reading TICKETING_API_KEY /
# ANALYTICS_API_KEY directly from this file -- fine for local dev, not how
# this should work once OPA is wired up.
OPA_DOMAIN=your-team.pam.okta.com
OPA_TEAM_NAME=your-opa-team
OPA_KEY_ID=
OPA_KEY_SECRET=
OPA_RESOURCE_GROUP_ID=
OPA_PROJECT_ID=
OPA_SECRET_ID=
TICKETING_API_KEY=ticketing-system-demo-key
ANALYTICS_API_KEY=analytics-system-demo-key

# Narration
ANTHROPIC_API_KEY=
